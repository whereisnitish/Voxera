# Application
APP_NAME=Voxera
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# Security
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# 32-byte urlsafe base64 key for AES-GCM (Fernet). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# Database
DATABASE_URL=postgresql+asyncpg://voxera:voxera@db:5432/voxera

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Default LLM (used when an agent does not specify a key)
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
